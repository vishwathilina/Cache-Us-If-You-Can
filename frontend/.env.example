# ─────────────────────────────────────────────────────────
# Nova Bank – Environment Variables
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# ── Auth0 (Frontend) ──────────────────────────────────────
# Create an Auth0 account at https://auth0.com
# Then create:
#   1. A "Single Page Application" for Next.js (AUTH0_CLIENT_ID / SECRET)
#   2. An "API" (Resource Server) for Spring Boot  (AUTH0_AUDIENCE)
#
# In Auth0 Dashboard → Applications → [your SPA]:
#   - Allowed Callback URLs: http://localhost:3000/api/auth/callback
#   - Allowed Logout URLs:   http://localhost:3000
#   - Allowed Web Origins:   http://localhost:3000

AUTH0_SECRET=dd58dfa43683a17a74fd5756f92229e54283084ae5d632faf61e0a51769b3918
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://dev-oszlmabpli7un4q2.us.auth0.com/
AUTH0_CLIENT_ID=JmqyoAZc77gPYChmhFdlxVVsiMGKTieF
AUTH0_CLIENT_SECRET=vN2jqGpVQL9EKYQQbhsiIhgQ0TA8aCmXohRxCSla3Q15pSRtzZ1Dwml_y0_qVuWR
AUTH0_AUDIENCE=https://api.novabank.com

# Custom claim namespace Auth0 injects roles into (via free Action)
AUTH0_ROLES_CLAIM=https://api.novabank.com/roles

# ── Auth0 (Backend / Spring Boot) ────────────────────────
# The backend reads these to validate JWT tokens
AUTH0_ISSUER_URI=https://dev-oszlmabpli7un4q2.us.auth0.com
# AUTH0_AUDIENCE matches above

# ── Database ──────────────────────────────────────────────
# For local Docker Compose dev (used by the db service):
# POSTGRES_USER=novabank
# POSTGRES_PASSWORD=supersecret
# POSTGRES_DB=novabank

# For Neon PostgreSQL (production) – overrides Docker db:
# DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-1.aws.neon.tech/neondb?user=xxx&password=xxx&sslmode=require

# For local Docker (set automatically in compose.yml from above vars):
# DATABASE_URL=jdbc:postgresql://db:5432/novabank?user=novabank&password=supersecret&sslmode=disable

# ── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
