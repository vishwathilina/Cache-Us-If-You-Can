# ─────────────────────────────────────────────────────────
# Nova Bank Backend – Environment Variables
# ─────────────────────────────────────────────────────────

# Neon PostgreSQL (production) or local Docker URL (dev)
DATABASE_URL=
# Auth0 – must match the API identifier you created in Auth0 dashboard
# e.g. https://YOUR_DOMAIN.auth0.com/  (note: trailing slash required)
AUTH0_ISSUER_URI=

# Must match AUTH0_AUDIENCE in the frontend .env.local
AUTH0_AUDIENCE=https://api.novabank.com

# Namespaced roles claim injected by your Auth0 Action
AUTH0_ROLES_CLAIM=https://api.novabank.com/roles

# CORS – comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# Server port
PORT=8080


